# Copy this file to .env and fill in your API keys.
# NEVER commit the .env file with real credentials.

# Anthropic API key (required for Claude CLI and anthropic Python client)
ANTHROPIC_API_KEY=

# OpenAI API key (optional — needed for OpenAI-backed LangChain/LlamaIndex chains)
OPENAI_API_KEY=

# HuggingFace access token (optional — needed for gated models on the Hub)
HUGGINGFACE_TOKEN=
