# ── Build context exclusions ─────────────────────────────────
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter checkpoints
.ipynb_checkpoints/
*.ipynb

# Data & model artefacts (mount at runtime instead of baking in)
data/
models/
*.bin
*.safetensors
*.gguf
*.pt
*.pth
*.ckpt

# Secrets — never bake API keys into the image
.env

# Editor / OS noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# Git
.git/
.gitignore
